# Shop Clock env vars
# Copy to .env.local and fill in.

# Postgres (Neon). On Vercel set DATABASE_URL to the pooled connection string.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Printavo GraphQL API — v2
# See C:\Dev\hq-print\scripts\enrich-printavo-garments.ts for reference.
# Auth is two headers: `email` + `token` (NOT Authorization).
PRINTAVO_API_URL="https://www.printavo.com/api/v2"
PRINTAVO_API_EMAIL="eric@craft-mfg.com"
PRINTAVO_API_TOKEN=""

# Admin sign-in — gates /admin/* and mutating /api/operators routes.
# Pick any strong password + a long random SESSION_SECRET (32+ chars).
# Rotating SESSION_SECRET invalidates everyone's admin cookies.
ADMIN_PASSWORD=""
SESSION_SECRET=""
